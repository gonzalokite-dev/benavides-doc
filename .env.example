# ─────────────────────────────────────────────
# Anthropic (Claude)
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─────────────────────────────────────────────
# Autenticación del equipo
# ─────────────────────────────────────────────
TEAM_PASSWORD=contraseña_segura_del_equipo
JWT_SECRET=un_secreto_largo_y_aleatorio_de_al_menos_32_caracteres

# ─────────────────────────────────────────────
# SharePoint / OneDrive
# URL base de la carpeta raíz en SharePoint (sin slash al final)
# ─────────────────────────────────────────────
SHAREPOINT_BASE_URL=https://tuempresa.sharepoint.com/sites/BenavidesAsociados/Shared%20Documents/BENAVIDES%20ASOCIADOS%20-%20GENERAL

# ─────────────────────────────────────────────
# Indexador — ruta local de la carpeta sincronizada con OneDrive
# (solo necesaria para ejecutar el indexador, no para la app web)
# ─────────────────────────────────────────────
LOCAL_DOCS_PATH=C:/Users/TuUsuario/OneDrive - Benavides Asociados/BENAVIDES ASOCIADOS - GENERAL

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=BenavidesDoc
